<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme -->
    <style name="Theme.Kalynt" parent="android:Theme.Material.NoActionBar">
        <item name="android:colorPrimary">@color/kalynt_primary</item>
        <item name="android:colorPrimaryDark">@color/kalynt_primary_dark</item>
        <item name="android:colorAccent">@color/kalynt_accent</item>
        <item name="android:windowBackground">@color/kalynt_background</item>
        <item name="android:statusBarColor">@color/kalynt_surface</item>
        <item name="android:navigationBarColor">@color/kalynt_surface</item>
    </style>
    
    <!-- Splash Screen Theme -->
    <style name="Theme.Kalynt.Splash" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@drawable/ic_notification</item>
        <item name="android:statusBarColor">@color/kalynt_background</item>
        <item name="android:navigationBarColor">@color/kalynt_background</item>
    </style>
    
    <!-- ZXing QR Scanner Theme -->
    <style name="zxing_CaptureTheme" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/kalynt_background</item>
        <item name="android:statusBarColor">@color/kalynt_background</item>
        <item name="android:navigationBarColor">@color/kalynt_background</item>
    </style>
</resources>